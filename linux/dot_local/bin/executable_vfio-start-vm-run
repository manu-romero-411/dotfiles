#!/bin/bash

function error(){
	RED='\033[1;31m'
	NC='\033[0m'
	printf "${RED}[ERROR] $@ ${NC}\n"
}

function info(){
	BLUE='\033[1;36m'
	NC='\033[0m'
	printf "${BLUE}[INFO] $@ ${NC}\n"
}


function check_root() {
	if [[ $(whoami) != root ]]; then
		error "No eres root"
		exit 1
	fi
}

if [ -z $1 ]; then
	error "Falta un argumento"
	exit 1
fi

MAQUINA_VM=""

if [[ "$1" == "-b" ]]; then
	cmdline=$(cat /proc/cmdline)
	if ! echo $cmdline | grep "vfio="; then
		exit 1
	fi
	MAQUINA_VM=$(echo $cmdline | grep -o 'vfio=[^ ]*' | cut -d"=" -f2)
else
	MAQUINA_VM=$1
fi

if ! virsh --connect qemu:///system list --all --name | grep -w $MAQUINA_VM >/dev/null; then
	error "La máquina virtual $MAQUINA_VM no existe. Prueba con:"
	virsh list --all --name
	exit 1
fi

if virsh list | grep "running" | grep "$MAQUINA_VM-nogpu"; then
	virsh destroy "$MAQUINA_VM-nogpu"
fi

#if pidof xfce4-session && [[ $1 != "-b" ]]; then
#	xfce4-session-logout -lf &
#	XFCESESSION=1
#	while [ $XFCESESSION != 0 ]; do
#		if ! pidof xfce4-session; then
#			XFCESESSION=0
#		fi
#		sleep 0.5
#	done
#
#fi

# qdbus org.kde.ksmserver /KSMServer logout 0 0 1
qdbus-qt6 org.kde.Shutdown /Shutdown logout

info "=== Iniciando $MAQUINA_VM -- $(date '+%a %d/%m/%Y %H:%M:%S') ==="
virsh start $MAQUINA_VM || exit 1
#virsh console $MAQUINA_VM
exit 0
