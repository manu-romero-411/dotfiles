#!/bin/bash
set -x
# Configuración de colores
RED='\033[1;31m'
BLUE='\033[1;36m'
NC='\033[0m'

function error() { printf "${RED}[ERROR] %s ${NC}\n" "$*"; }
function info()  { printf "${BLUE}[INFO] %s ${NC}\n" "$*"; }

# 1. Validaciones iniciales
if [ -z "$1" ]; then
    error "Falta el nombre de la VM o el argumento -b"
    exit 1
fi

# 2. Lógica de selección de VM
MAQUINA_VM=""
if [[ "$1" == "-b" ]]; then
    cmdline=$(cat /proc/cmdline)
    if [[ ! $cmdline =~ vfio=([^ ]+) ]]; then
        error "No se encontró el parámetro vfio= en /proc/cmdline"
        exit 1
    fi
    MAQUINA_VM="${BASH_REMATCH[1]}"
else
    MAQUINA_VM="$1"
fi

# Verificar existencia de la VM
if ! virsh list --all --name | grep -qx "$MAQUINA_VM"; then
    error "La máquina virtual '$MAQUINA_VM' no existe."
    exit 1
fi

# 3. Cerrar sesión de Plasma KDE de forma elegante
info "Cerrando sesión de KDE Plasma..."

# Obtenemos el usuario que lanzó el sudo
REAL_USER="${SUDO_USER:-$USER}"
USER_ID=$(id -u "$REAL_USER")

# Ejecutamos el logout como el usuario de la sesión
sudo -u "$REAL_USER" DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/"$USER_ID"/bus \
    qdbus-qt6 org.kde.Shutdown /Shutdown logout

# 4. Bucle de espera crucial
info "Esperando a que la sesión de usuario finalice completamente..."

MAX_RETRIES=60
COUNT=0

# Esperamos a que el proceso principal de Plasma desaparezca
while pgrep -u "$USER_ID" -x "plasmashell" > /dev/null; do
    sleep 0.5
    ((COUNT++))
    if [ $COUNT -ge $MAX_RETRIES ]; then
        error "Tiempo de espera agotado. Algunos procesos de Plasma siguen vivos."
        info "Forzando cierre de procesos restantes del usuario..."
        skill -u "$REAL_USER"
        break
    fi
done

# Respiro extra para que el driver termine de limpiar
sleep 2

info "=== Iniciando $MAQUINA_VM -- $(date '+%H:%M:%S') ==="

# 5. Ejecución de la VM
if virsh start "$MAQUINA_VM"; then
    info "VM iniciada con éxito."
else
    error "Fallo al iniciar la VM."
    exit 1
fi

exit 0
