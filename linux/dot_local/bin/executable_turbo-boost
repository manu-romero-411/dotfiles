#!/bin/bash

if [ $(id -u) -ne 0 ]; then
	echo "[ERROR] Se necesitan privilegios de root."
	exit 1
fi

case $1 in
	"on"|"enable"|"1") echo 1 | tee /sys/devices/system/cpu/cpufreq/boost ;;
	"off"|"disable"|"0") echo 0 | tee /sys/devices/system/cpu/cpufreq/boost ;;
	*) echo "Uso: $0 {on|off||1|0||enable|disable}"; exit 1;;
esac

exit 0
