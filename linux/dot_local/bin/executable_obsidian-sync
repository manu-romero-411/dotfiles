#!/bin/bash

set -uo pipefail

MANUBLOGC="/home/manuel/Documentos/manuVault"
if [ ! -d "$MANUBLOGC" ]; then
	echo "[ERROR] No existe el directorio $MANUBLOGC"
	exit 1
fi

DISPOSITIVO=ryzencraft

function git_add(){
	git add .obsidian
	git add .obsidian/*
	git add -A
}

cd "$MANUBLOGC"
git_add

echo "=== COMMIT ==="
git commit -m "Commit desde $DISPOSITIVO - $(date)"

echo "=== MERGE ==="
for i in movil macbook; do
        git fetch origin $i
        find .git/objects -type f -empty -print -delete
        git merge -m "Clonar cambios de $i en $DISPOSITIVO - $(date)" --no-ff origin/$i
	git checkout --theirs *
        find .git/objects -type f -empty -print -delete
done
git_add
git commit -a -m "Merge - $(date)"
echo "=== PUSH ==="
git push -u origin $DISPOSITIVO
#if pidof obsidian; then
#	killall obsidian
#	xdg-open /usr/share/applications/obsidian.desktop
#fi

echo ""
#read -rsn1 -p "$(tput setaf 11)Pulsa cualquier tecla para continuar...";echo
echo ""

exit 0
