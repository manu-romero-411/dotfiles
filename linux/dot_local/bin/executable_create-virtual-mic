#!/usr/bin/env bash
set -e

OUT_HDMI="alsa_output.pci-0000_01_00.1.hdmi-stereo"
OUT_ANALOG="alsa_output.pci-0000_05_00.6.analog-stereo"

SRC_HDMI="virtual_mic_hdmi"
SRC_ANALOG="virtual_mic_analog"

cleanup() {
    local found=0
    for name in "$SRC_HDMI" "$SRC_ANALOG"; do
        while read -r mid _; do
            pactl unload-module "$mid" 2>/dev/null && echo "  unloaded $name ($mid)" && found=1
        done < <(pactl list short modules | grep "source_name=${name}")
    done
    [[ $found -eq 1 ]] && echo "✓ Limpieza completada" || echo "Nada que limpiar"
}

case "${1:-}" in
    -d|--disable) cleanup; exit 0 ;;
    ""|--enable)  ;;
    *) echo "Uso: $0 [--enable|--disable|-d]" >&2; exit 1 ;;
esac

cleanup 2>/dev/null || true

for mon in "${OUT_HDMI}.monitor" "${OUT_ANALOG}.monitor"; do
    pactl list short sources | awk '{print $2}' | grep -q "^${mon}$" \
        || echo "Aviso: monitor no encontrado: ${mon}" >&2
done

pactl load-module module-remap-source \
    source_name="$SRC_HDMI" \
    master="${OUT_HDMI}.monitor" \
    source_properties=device.description="hdmi_loopback" \
    channels=2

pactl load-module module-remap-source \
    source_name="$SRC_ANALOG" \
    master="${OUT_ANALOG}.monitor" \
    source_properties=device.description="analog_loopback" \
    channels=2

echo "✓ Micrófonos virtuales activos:"
pactl list short sources | grep -E "$SRC_HDMI|$SRC_ANALOG"
