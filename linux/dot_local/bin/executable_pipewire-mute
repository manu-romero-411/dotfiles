#!/bin/bash

# 1. Obtener los IDs de los sinks (salidas)
# Buscamos los nombres técnicos para que el script sea preciso
HDMI_ID=$(wpctl status | grep -i "HDMI" | head -n 1 | grep -oP '\d+(?=\.)' | head -n 1)
INTERNAL_ID=$(wpctl status | grep -i "Altavoces internos o sonido Jack" | head -n 1 | grep -oP '\d+(?=\.)' | head -n 1)

# 2. Obtener el ID del sink que está activo actualmente (marcado con *)
CURRENT_ID=$(wpctl status | grep "\*" | grep -oP '\d+(?=\.)' | head -n 1)

# 3. Lógica de conmutación
if [ "$CURRENT_ID" == "$INTERNAL_ID" ]; then
    wpctl set-default $HDMI_ID
#    notify-send "Audio Output" "Cambiado a: HDMI" --icon=video-display
else
    wpctl set-default $INTERNAL_ID
#    notify-send "Audio Output" "Cambiado a: Altavoces Internos" --icon=audio-speakers
fi
