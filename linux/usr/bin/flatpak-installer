#!/bin/bash
## INSTALADOR DE ARCHIVOS FLATPAKREF (DESCARGAS DE FLATHUB)
## FECHA: Martes 13 de junio de 2023

if [ -z $1 ] || [ ! -z $2 ] || ! echo $1 | grep "flatpakref" > /dev/null; then
	echo "[ERROR] Argumento inválido"
	exit 1
fi

FLATINST=$(cat "$1" | grep "Name=" | grep -v "SuggestRemoteName=" | head -n 1 | cut -d"=" -f2)
FLATREMO=$(cat "$1" | grep "SuggestRemoteName=" | head -n 1 | cut -d"=" -f2)

flatpak install "$FLATREMO" "$FLATINST"
ERRORCODE=$?

read -rsn1 -p "$(tput setaf 11)Pulsa cualquier tecla para continuar...";echo

exit $ERRORCODE
